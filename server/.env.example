# Скопируйте этот файл в .env и заполните значения.

# Строка подключения к бесплатной онлайн-БД MongoDB Atlas (https://www.mongodb.com/atlas/database).
# Пример: mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/novatech?retryWrites=true&w=majority
MONGODB_URI=

# Секрет для подписи JWT-токенов
JWT_SECRET=change-me-to-a-long-random-string

# Порт API-сервера
PORT=4000
